# Copy this file to .env and fill in your values
# These are used during build time (Vite prefix: VITE_)

# Zapier / webhook endpoint for booking and contact notifications
VITE_BOOK_CALL_WEBHOOK_URL=
VITE_CONTACT_WEBHOOK_URL=
VITE_ZAPIER_WEBHOOK_URL=

# EmailJS delivery (recommended for direct email sending from the site)
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_PUBLIC_KEY=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_BOOKING_TEMPLATE_ID=
VITE_EMAILJS_CONTACT_TEMPLATE_ID=

# Optional Cal.com meeting link for the confirmation message
VITE_CAL_COM_LINK=
