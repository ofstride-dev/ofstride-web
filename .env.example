# Copy this file to .env and fill in your values
# These are used during build time (Vite prefix: VITE_)

# Web3Forms API Key (get from https://web3forms.com/)
VITE_WEB3FORMS_KEY=your-web3forms-key-here

# Cal.com username (e.g., "ofstride")
VITE_CAL_USERNAME=ofstride

# Cal.com event slug (e.g., "30min")
VITE_CAL_EVENT_SLUG=30min

# api/.env (mock-friendly defaults for local testing)
ENV=dev
LOG_LEVEL=INFO

# Primary LLM - mock by default for local testing
LLM_PROVIDER=mock
MODEL_NAME=gpt-4o-mini
FALLBACK_MODEL_NAME=gpt-4o-mini
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=700
ALLOW_MOCK_PROVIDER=true

# Live OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-key-here

# Azure OpenAI Configuration
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=

# Embedding
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# Qdrant (with in-memory fallback)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=ac5bf3cb-9b9a-4098-80fc-4f56e1e9c4a6
QDRANT_COLLECTION=ofstride_consultants
USE_INMEMORY_VECTOR_STORE=true

# Retrieval
RETRIEVAL_K=6
SOURCE_SNIPPET_CHARS=420
INGEST_CHUNK_SIZE=1400
INGEST_CHUNK_OVERLAP=200

# Observability
LANGFUSE_PUBLIC_KEY=pk-lf-f3dd8f31-4788-4938-8193-efcec68f8a35
LANGFUSE_SECRET_KEY=sk-lf-4a2faa8f-86d2-49e8-b95f-c9940d614b29
LANGFUSE_HOST=https://cloud.langfuse.com

# Sessions
SESSION_STORAGE_TYPE=memory
SESSION_TTL_MINUTES=30
SESSION_MAX_MESSAGES=16

# Fallback providers
GEMINI_API_KEY=AAQ.Ab8RN6JuhIedadmcahexq787FOWb57msLYs2Hah6BRaAExQ3XQ
GEMINI_MODEL=gemini-1.5-flash

# Storage
AZURE_STORAGE_CONNECTION_STRING=
