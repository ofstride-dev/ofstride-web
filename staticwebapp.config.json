{
  "platform": {
    "apiRuntime": "python:3.12"
  },
  "routes": [
    {
      "route": "/api/*",
      "methods": ["GET", "POST", "OPTIONS", "PUT", "DELETE"],
      "headers": {
        "Access-Control-Allow-Origin": "*",
        "Access-Control-Allow-Methods": "GET, POST, OPTIONS, PUT, DELETE",
        "Access-Control-Allow-Headers": "Content-Type, Authorization, x-admin-key, x-ms-blob-type",
        "Access-Control-Expose-Headers": "x-ms-request-id"
      }
    },
    {
      "route": "/*",
      "serve": "/index.html",
      "statusCode": 200
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/api/*", "/assets/*"]
  },
  "responseOverrides": {
    "404": {
      "rewrite": "/index.html",
      "statusCode": 200
    }
  }
}